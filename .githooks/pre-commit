#!/bin/sh
# .githooks/pre-commit — rebuilds single-file mobile bundles for any app
# whose source files are changing.

ROOT="$(git rev-parse --show-toplevel)"

# Detect changes per app
CHANGED_APPS=""
for APP in particle-zoo big-bang; do
  if git diff --cached --name-only | grep -qE "^${APP}/(index\.html|styles\.css|i18n\.js|app\.js|build\.js)$"; then
    CHANGED_APPS="$CHANGED_APPS $APP"
  fi
done

if [ -n "$CHANGED_APPS" ]; then
  if ! command -v node >/dev/null 2>&1; then
    echo "⚠ node not found — cannot rebuild single-file version. Install Node.js or run 'node <app>/build.js' manually before committing."
    exit 1
  fi
  for APP in $CHANGED_APPS; do
    echo "→ Rebuilding single-file version for $APP..."
    (cd "$ROOT/$APP" && node build.js)
    git add "$ROOT/$APP/mobile/"*.html
  done
  echo "→ single-file builds updated & staged."
fi
